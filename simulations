<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Digital Signal Frequency Measurement System</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{--crt:#00ff88;--crt2:#00ccff;--crt3:#ff6b35;--crt4:#ffcc00;--bg:#0a0f0a;--panel:rgba(0,255,136,0.05);--brd:rgba(0,255,136,0.25);--brd2:rgba(0,204,255,0.25)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Share Tech Mono',monospace;background:var(--bg);color:var(--crt);padding:16px;min-height:100vh;position:relative}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.07) 2px,rgba(0,0,0,0.07) 4px);pointer-events:none;z-index:100}
.hdr{display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--brd);padding-bottom:10px;margin-bottom:14px}
.hdr-title{font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:600;letter-spacing:2px;text-transform:uppercase}
.hdr-title span{color:var(--crt2)}
.sdot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--crt);margin-right:6px;animation:blink 1.2s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.sys-id{font-size:11px;color:rgba(0,255,136,.4)}
.main-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.full-row{margin-bottom:12px}
.panel{background:var(--panel);border:1px solid var(--brd);border-radius:4px;padding:12px;position:relative}
.panel-blue{border-color:var(--brd2);background:rgba(0,204,255,.04)}
.panel-amber{border-color:rgba(255,204,0,.25);background:rgba(255,204,0,.04)}
.panel-red{border-color:rgba(255,107,53,.3);background:rgba(255,107,53,.04)}
.plabel{font-family:'Rajdhani',sans-serif;font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(0,255,136,.5);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.plabel::before{content:'';display:inline-block;width:14px;height:1px;background:currentColor}
.plabel.blue{color:rgba(0,204,255,.5)}.plabel.amber{color:rgba(255,204,0,.5)}.plabel.red{color:rgba(255,107,53,.5)}
.freq-display{font-size:38px;color:var(--crt);letter-spacing:3px;line-height:1;text-shadow:0 0 16px rgba(0,255,136,.4)}
.freq-unit{font-size:16px;color:rgba(0,255,136,.6);margin-left:4px}
.freq-period{font-size:13px;color:rgba(0,255,136,.5);margin-top:6px}
.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px}
.metric{background:rgba(0,0,0,.3);border:1px solid rgba(0,255,136,.12);border-radius:3px;padding:8px;text-align:center}
.metric-val{font-size:16px;color:var(--crt)}
.metric-lbl{font-size:10px;color:rgba(0,255,136,.4);margin-top:2px;letter-spacing:1px;text-transform:uppercase}
canvas{display:block;width:100%}
.canvas-wrap{position:relative;background:rgba(0,0,0,.4);border:1px solid rgba(0,255,136,.15);border-radius:3px;overflow:hidden}
.canvas-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,255,136,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,.05) 1px,transparent 1px);background-size:40px 20px;pointer-events:none}
.ch-lbl{position:absolute;top:4px;left:6px;font-size:10px;letter-spacing:1px}
.la-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.la-ch{font-size:11px;min-width:24px}
.la-cwrap{flex:1;background:rgba(0,0,0,.4);border:1px solid rgba(0,255,136,.1);border-radius:2px;overflow:hidden;height:28px}
.la-sig{width:100%;height:100%;display:block}
.la-val{font-size:11px;min-width:48px;text-align:right}
.ctrl-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.ctrl-item{display:flex;flex-direction:column;gap:4px}
.ctrl-lbl{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:rgba(0,255,136,.45)}
input[type=range]{-webkit-appearance:none;width:100%;height:3px;background:rgba(0,255,136,.2);border-radius:2px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:12px;height:12px;border-radius:50%;background:var(--crt);border:2px solid var(--bg);box-shadow:0 0 6px rgba(0,255,136,.6)}
.ctrl-readout{font-size:13px;color:var(--crt)}
select{background:#0a130a;border:1px solid var(--brd);color:var(--crt);font-family:'Share Tech Mono',monospace;font-size:12px;padding:4px 6px;border-radius:3px;outline:none;cursor:pointer;width:100%}
.btn-row{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.btn{font-family:'Share Tech Mono',monospace;font-size:11px;padding:6px 14px;border:1px solid var(--brd);background:transparent;color:var(--crt);cursor:pointer;border-radius:3px;letter-spacing:1px;text-transform:uppercase;transition:all .15s}
.btn:hover{background:rgba(0,255,136,.1);border-color:var(--crt)}
.btn.active{background:rgba(0,255,136,.15);border-color:var(--crt);box-shadow:0 0 8px rgba(0,255,136,.3)}
.btn-blue{border-color:var(--brd2);color:var(--crt2)}.btn-blue:hover{background:rgba(0,204,255,.1);border-color:var(--crt2)}
.btn-amber{border-color:rgba(255,204,0,.3);color:var(--crt4)}.btn-amber:hover{background:rgba(255,204,0,.1);border-color:var(--crt4)}
.tab-bar{display:flex;gap:2px;margin-bottom:10px;border-bottom:1px solid var(--brd);padding-bottom:6px;flex-wrap:wrap}
.tab{font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;padding:4px 12px;cursor:pointer;color:rgba(0,255,136,.4);border-radius:3px 3px 0 0;transition:all .15s}
.tab.active{color:var(--crt);background:rgba(0,255,136,.08);border:1px solid var(--brd);border-bottom:none}
.tab-content{display:none}.tab-content.active{display:block}
.code-block{background:rgba(0,0,0,.5);border:1px solid rgba(0,255,136,.12);border-radius:3px;padding:10px;font-size:11px;line-height:1.7;overflow-x:auto;max-height:230px;overflow-y:auto}
.code-block::-webkit-scrollbar{width:4px;height:4px}
.code-block::-webkit-scrollbar-thumb{background:rgba(0,255,136,.3);border-radius:2px}
.kw{color:#ff6b35}.cm{color:rgba(0,255,136,.35);font-style:italic}.str{color:#ffcc00}.num{color:#00ccff}.fn{color:#88ffcc}
.veri-table{width:100%;font-size:11px;border-collapse:collapse}
.veri-table th{color:rgba(0,255,136,.5);font-weight:400;letter-spacing:1px;text-transform:uppercase;padding:4px 8px;border-bottom:1px solid var(--brd);text-align:left}
.veri-table td{padding:5px 8px;border-bottom:1px solid rgba(0,255,136,.07)}
.veri-table tr:hover td{background:rgba(0,255,136,.04)}
.pass{color:#00ff88}.fail{color:#ff6b35}.warn{color:#ffcc00}
.event-log{background:rgba(0,0,0,.4);border:1px solid rgba(0,255,136,.12);border-radius:3px;padding:8px;height:100px;overflow-y:auto;font-size:11px;line-height:1.9}
.event-log::-webkit-scrollbar{width:3px}
.event-log::-webkit-scrollbar-thumb{background:rgba(0,255,136,.3)}
.evt-ok{color:var(--crt)}.evt-warn{color:var(--crt4)}.evt-err{color:var(--crt3)}.evt-info{color:var(--crt2)}
.evt-ts{color:rgba(0,255,136,.3);margin-right:6px}
</style>
</head>
<body>
<div class="hdr">
  <div>
    <div class="hdr-title"><span class="sdot"></span>Digital <span>Signal Frequency</span> Measurement System</div>
    <div class="sys-id">DSFMS-v2.4 &nbsp;|&nbsp; FPGA/MCU Simulation &nbsp;|&nbsp; Real-Time Mode</div>
  </div>
  <div style="text-align:right;font-size:11px;color:rgba(0,255,136,.35)">
    <div id="clock-display">00:00:00.000</div>
    <div id="sample-count">SAMPLES: 0</div>
  </div>
</div>

<div class="tab-bar">
  <div class="tab active" onclick="switchTab('simulation')">▶ Simulation</div>
  <div class="tab" onclick="switchTab('design')">⬡ Design</div>
  <div class="tab" onclick="switchTab('implementation')">{ } Implementation</div>
  <div class="tab" onclick="switchTab('logic')">≋ Logic Analyzer</div>
  <div class="tab" onclick="switchTab('verification')">✓ Verification</div>
</div>

<!-- SIMULATION -->
<div class="tab-content active" id="tab-simulation">
  <div class="main-grid">
    <div class="panel">
      <div class="plabel">Measured Frequency</div>
      <div class="freq-display" id="freq-readout">1000.00 <span class="freq-unit">Hz</span></div>
      <div class="freq-period" id="period-readout">Period: 1.000 ms | ω = 6283.2 rad/s</div>
      <div class="metrics">
        <div class="metric"><div class="metric-val" id="met-duty">50.0%</div><div class="metric-lbl">Duty Cycle</div></div>
        <div class="metric"><div class="metric-val" id="met-rise">500ns</div><div class="metric-lbl">Rise Time</div></div>
        <div class="metric"><div class="metric-val" id="met-jitter">±2ns</div><div class="metric-lbl">Jitter</div></div>
      </div>
      <div class="metrics" style="margin-top:8px">
        <div class="metric"><div class="metric-val" id="met-volt">3.3V</div><div class="metric-lbl">V High</div></div>
        <div class="metric"><div class="metric-val" id="met-snr">62dB</div><div class="metric-lbl">SNR</div></div>
        <div class="metric"><div class="metric-val" id="met-edges">2000</div><div class="metric-lbl">Edges/s</div></div>
      </div>
    </div>
    <div class="panel panel-blue">
      <div class="plabel blue">Oscilloscope — CH1 (Input Signal)</div>
      <div class="canvas-wrap">
        <div class="canvas-grid"></div>
        <div class="ch-lbl" style="color:#00ccff">CH1 &nbsp; 1V/div &nbsp; TIME: <span id="timebase-lbl">1ms/div</span></div>
        <canvas id="osc-canvas" style="height:90px"></canvas>
      </div>
      <div class="canvas-wrap" style="margin-top:6px">
        <div class="canvas-grid"></div>
        <div class="ch-lbl" style="color:#ff6b35">CH2 &nbsp; Gate Signal</div>
        <canvas id="gate-canvas" style="height:40px"></canvas>
      </div>
    </div>
  </div>
  <div class="panel full-row">
    <div class="plabel">Signal Generator & Measurement Controls</div>
    <div class="ctrl-grid">
      <div class="ctrl-item">
        <div class="ctrl-lbl">Frequency</div>
        <input type="range" id="freq-ctrl" min="0" max="100" value="30" oninput="updateFreq(this.value)">
        <div class="ctrl-readout"><span id="freq-ctrl-val">1.00 kHz</span></div>
      </div>
      <div class="ctrl-item">
        <div class="ctrl-lbl">Duty Cycle</div>
        <input type="range" id="duty-ctrl" min="5" max="95" value="50" oninput="updateDuty(this.value)">
        <div class="ctrl-readout"><span id="duty-ctrl-val">50%</span></div>
      </div>
      <div class="ctrl-item">
        <div class="ctrl-lbl">Noise Level</div>
        <input type="range" id="noise-ctrl" min="0" max="100" value="10" oninput="updateNoise(this.value)">
        <div class="ctrl-readout"><span id="noise-ctrl-val">10%</span></div>
      </div>
      <div class="ctrl-item">
        <div class="ctrl-lbl">Waveform Type</div>
        <select id="wave-type" onchange="updateWave(this.value)">
          <option value="square">Square</option>
          <option value="sine">Sine → Square</option>
          <option value="pwm">PWM Burst</option>
          <option value="glitch">Glitched</option>
        </select>
      </div>
      <div class="ctrl-item">
        <div class="ctrl-lbl">Gate Time</div>
        <select id="gate-time">
          <option value="100">100ms</option>
          <option value="1000" selected>1s Gate</option>
          <option value="10000">10s Gate</option>
        </select>
      </div>
      <div class="ctrl-item">
        <div class="ctrl-lbl">Prescaler</div>
        <select id="prescaler">
          <option value="1">÷1 (direct)</option>
          <option value="2">÷2</option>
          <option value="10">÷10</option>
          <option value="100">÷100</option>
        </select>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn active" id="btn-run" onclick="toggleRun()">■ RUNNING</button>
      <button class="btn btn-blue" onclick="triggerSingle()">⊡ SINGLE</button>
      <button class="btn btn-amber" onclick="autoRange()">⊞ AUTO RANGE</button>
      <button class="btn" onclick="resetStats()">↺ RESET STATS</button>
      <button class="btn btn-blue" onclick="switchTab('logic')">≋ OPEN LOGIC ANALYZER</button>
    </div>
  </div>
  <div class="panel panel-amber full-row">
    <div class="plabel amber">System Event Log</div>
    <div class="event-log" id="evt-log"></div>
  </div>
</div>

<!-- DESIGN -->
<div class="tab-content" id="tab-design">
  <div class="main-grid">
    <div class="panel">
      <div class="plabel">System Architecture</div>
      <svg width="100%" viewBox="0 0 380 320" xmlns="http://www.w3.org/2000/svg" style="background:rgba(0,0,0,.3);border-radius:3px">
        <defs><marker id="da" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M2 1L8 5L2 9" fill="none" stroke="#00ff88" stroke-width="2" stroke-linecap="round"/></marker></defs>
        <rect x="10" y="130" width="70" height="36" rx="4" fill="rgba(0,255,136,.06)" stroke="#00ff88" stroke-width="0.6" stroke-opacity="0.4"/>
        <text x="45" y="145" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ff88" opacity="0.7">SIG INPUT</text>
        <text x="45" y="158" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.4">0–5V Digital</text>
        <line x1="80" y1="148" x2="108" y2="148" stroke="#00ff88" stroke-width="0.8" marker-end="url(#da)" opacity="0.6"/>
        <rect x="110" y="130" width="64" height="36" rx="4" fill="rgba(0,204,255,.06)" stroke="#00ccff" stroke-width="0.6" stroke-opacity="0.4"/>
        <text x="142" y="145" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ccff" opacity="0.7">SCHMITT</text>
        <text x="142" y="157" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ccff" opacity="0.4">Trigger</text>
        <line x1="174" y1="148" x2="200" y2="148" stroke="#00ff88" stroke-width="0.8" marker-end="url(#da)" opacity="0.6"/>
        <rect x="202" y="130" width="60" height="36" rx="4" fill="rgba(255,204,0,.06)" stroke="#ffcc00" stroke-width="0.6" stroke-opacity="0.4"/>
        <text x="232" y="145" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#ffcc00" opacity="0.7">PRESCALER</text>
        <text x="232" y="157" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#ffcc00" opacity="0.4">÷N Counter</text>
        <line x1="262" y1="148" x2="290" y2="148" stroke="#00ff88" stroke-width="0.8" marker-end="url(#da)" opacity="0.6"/>
        <rect x="292" y="120" width="72" height="56" rx="4" fill="rgba(0,255,136,.08)" stroke="#00ff88" stroke-width="0.6" stroke-opacity="0.5"/>
        <text x="328" y="140" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ff88" opacity="0.8">32-BIT</text>
        <text x="328" y="152" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ff88" opacity="0.8">COUNTER</text>
        <text x="328" y="165" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.4">Synchronous</text>
        <rect x="178" y="210" width="80" height="36" rx="4" fill="rgba(255,107,53,.06)" stroke="#ff6b35" stroke-width="0.6" stroke-opacity="0.4"/>
        <text x="218" y="225" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#ff6b35" opacity="0.7">REF CLOCK</text>
        <text x="218" y="237" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#ff6b35" opacity="0.4">10 MHz TCXO</text>
        <rect x="292" y="210" width="72" height="36" rx="4" fill="rgba(0,204,255,.06)" stroke="#00ccff" stroke-width="0.6" stroke-opacity="0.4"/>
        <text x="328" y="225" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ccff" opacity="0.7">GATE CTRL</text>
        <text x="328" y="237" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ccff" opacity="0.4">Timebase Gen</text>
        <rect x="140" y="26" width="100" height="60" rx="4" fill="rgba(0,255,136,.04)" stroke="#00ff88" stroke-width="0.8" stroke-opacity="0.6"/>
        <text x="190" y="47" text-anchor="middle" font-family="Share Tech Mono" font-size="10" fill="#00ff88" opacity="0.9">MCU / FPGA</text>
        <text x="190" y="60" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.5">Compute Engine</text>
        <text x="190" y="72" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.5">Result Register</text>
        <rect x="10" y="26" width="80" height="36" rx="4" fill="rgba(0,255,136,.06)" stroke="#00ff88" stroke-width="0.5" stroke-opacity="0.3"/>
        <text x="50" y="42" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#00ff88" opacity="0.6">7-SEG</text>
        <text x="50" y="54" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.4">Display</text>
        <rect x="290" y="26" width="80" height="36" rx="4" fill="rgba(255,204,0,.05)" stroke="#ffcc00" stroke-width="0.5" stroke-opacity="0.3"/>
        <text x="330" y="42" text-anchor="middle" font-family="Share Tech Mono" font-size="9" fill="#ffcc00" opacity="0.6">UART / SPI</text>
        <text x="330" y="54" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#ffcc00" opacity="0.4">Output Bus</text>
        <line x1="328" y1="120" x2="328" y2="80" stroke="#00ff88" stroke-width="0.5" opacity="0.3" stroke-dasharray="3 2"/>
        <line x1="328" y1="80" x2="240" y2="80" stroke="#00ff88" stroke-width="0.5" opacity="0.3" stroke-dasharray="3 2" marker-end="url(#da)"/>
        <line x1="140" y1="56" x2="90" y2="56" stroke="#00ff88" stroke-width="0.5" opacity="0.3" stroke-dasharray="3 2" marker-end="url(#da)"/>
        <line x1="240" y1="56" x2="290" y2="44" stroke="#ffcc00" stroke-width="0.5" opacity="0.3" stroke-dasharray="3 2" marker-end="url(#da)"/>
        <line x1="258" y1="228" x2="290" y2="228" stroke="#ff6b35" stroke-width="0.6" opacity="0.5" marker-end="url(#da)"/>
        <line x1="328" y1="210" x2="328" y2="176" stroke="#00ccff" stroke-width="0.6" opacity="0.5" marker-end="url(#da)"/>
        <text x="190" y="298" text-anchor="middle" font-family="Share Tech Mono" font-size="8" fill="#00ff88" opacity="0.25">Measurement Resolution: 0.1 Hz @ 1s gate | Error &lt;1ppm TCXO</text>
      </svg>
    </div>
    <div>
      <div class="panel" style="margin-bottom:12px">
        <div class="plabel">Design Specifications</div>
        <div style="font-size:11px;line-height:2.1;color:rgba(0,255,136,.7)">
          <div>FREQ RANGE  &nbsp;&nbsp; <span style="color:var(--crt2)">1 Hz → 100 MHz</span></div>
          <div>RESOLUTION  &nbsp;&nbsp; <span style="color:var(--crt2)">0.1 Hz (1s gate)</span></div>
          <div>ACCURACY    &nbsp;&nbsp; <span style="color:var(--crt2)">&lt; 1 ppm (TCXO)</span></div>
          <div>INPUT VOLT  &nbsp;&nbsp; <span style="color:var(--crt2)">0V – 5V TTL/CMOS</span></div>
          <div>PRESCALER   &nbsp;&nbsp; <span style="color:var(--crt2)">÷1, ÷2, ÷10, ÷100</span></div>
          <div>COUNTER     &nbsp;&nbsp; <span style="color:var(--crt2)">32-bit synchronous</span></div>
          <div>INTERFACE   &nbsp;&nbsp; <span style="color:var(--crt2)">UART 115200 baud</span></div>
          <div>REF CLK     &nbsp;&nbsp; <span style="color:var(--crt2)">10 MHz TCXO ±1ppm</span></div>
          <div>GATE TIMES  &nbsp;&nbsp; <span style="color:var(--crt2)">100ms / 1s / 10s</span></div>
          <div>DISPLAY     &nbsp;&nbsp; <span style="color:var(--crt2)">6-digit 7-segment</span></div>
        </div>
      </div>
      <div class="panel panel-amber">
        <div class="plabel amber">Method — Reciprocal Counting</div>
        <div style="font-size:11px;line-height:1.9;color:rgba(255,204,0,.7)">
          <div>f = N_edges / T_gate</div>
          <div>Period = T_gate / N_edges</div>
          <div style="margin-top:6px;color:rgba(255,204,0,.5)">Reciprocal method measures both</div>
          <div style="color:rgba(255,204,0,.5)">rising and falling edges for high</div>
          <div style="color:rgba(255,204,0,.5)">accuracy at low frequencies.</div>
          <div style="margin-top:6px">Error = ±1 count / (f × T_gate)</div>
          <div>At 1kHz, 1s gate: error = 0.1%</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- IMPLEMENTATION -->
<div class="tab-content" id="tab-implementation">
  <div class="main-grid">
    <div class="panel">
      <div class="plabel">Verilog HDL — Frequency Counter Core</div>
      <div class="code-block"><span class="cm">// Digital Frequency Counter — Synthesizable RTL</span>
<span class="kw">module</span> <span class="fn">freq_counter</span> #(
  <span class="kw">parameter</span> REF_CLK_HZ = <span class="num">10_000_000</span>,
  <span class="kw">parameter</span> GATE_MS    = <span class="num">1000</span>
)(
  <span class="kw">input</span>  wire clk_ref,   <span class="cm">// 10 MHz TCXO</span>
  <span class="kw">input</span>  wire sig_in,    <span class="cm">// Input signal</span>
  <span class="kw">input</span>  wire rst_n,     <span class="cm">// Active-low reset</span>
  <span class="kw">output</span> reg  [<span class="num">31</span>:<span class="num">0</span>] freq_hz,
  <span class="kw">output</span> reg  data_valid
);
  <span class="kw">localparam</span> GATE_TICKS = REF_CLK_HZ * GATE_MS / <span class="num">1000</span>;
  <span class="kw">reg</span> [<span class="num">23</span>:<span class="num">0</span>] gate_cnt;
  <span class="kw">reg</span>        gate_en;
  <span class="kw">reg</span> [<span class="num">31</span>:<span class="num">0</span>] edge_cnt;
  <span class="kw">reg</span>        sig_prev;

  <span class="kw">always</span> @(<span class="kw">posedge</span> clk_ref <span class="kw">or negedge</span> rst_n) <span class="kw">begin</span>
    <span class="kw">if</span> (!rst_n) <span class="kw">begin</span>
      gate_cnt &lt;= <span class="num">0</span>; gate_en &lt;= <span class="num">1</span>;
      edge_cnt &lt;= <span class="num">0</span>; sig_prev &lt;= <span class="num">0</span>;
      freq_hz  &lt;= <span class="num">0</span>; data_valid &lt;= <span class="num">0</span>;
    <span class="kw">end else begin</span>
      sig_prev   &lt;= sig_in;
      data_valid &lt;= <span class="num">0</span>;
      <span class="kw">if</span> (gate_en) <span class="kw">begin</span>
        <span class="kw">if</span> (sig_in &amp;&amp; !sig_prev) edge_cnt &lt;= edge_cnt + <span class="num">1</span>;
        <span class="kw">if</span> (gate_cnt == GATE_TICKS - <span class="num">1</span>) <span class="kw">begin</span>
          gate_cnt   &lt;= <span class="num">0</span>;
          freq_hz    &lt;= edge_cnt;
          edge_cnt   &lt;= <span class="num">0</span>;
          data_valid &lt;= <span class="num">1</span>;
        <span class="kw">end else</span>
          gate_cnt &lt;= gate_cnt + <span class="num">1</span>;
      <span class="kw">end</span>
    <span class="kw">end</span>
  <span class="kw">end</span>
<span class="kw">endmodule</span></div>
    </div>
    <div>
      <div class="panel panel-blue" style="margin-bottom:12px">
        <div class="plabel blue">C Firmware — MCU Driver (STM32)</div>
        <div class="code-block"><span class="cm">// STM32 HAL — Frequency Measurement ISR</span>
<span class="num">#include</span> <span class="str">"stm32f4xx_hal.h"</span>

<span class="kw">volatile uint32_t</span> edge_count = <span class="num">0</span>;
<span class="kw">volatile uint32_t</span> freq_result = <span class="num">0</span>;
<span class="kw">volatile uint8_t</span>  meas_done  = <span class="num">0</span>;

<span class="cm">/* TIM2 input capture callback */</span>
<span class="kw">void</span> <span class="fn">HAL_TIM_IC_CaptureCallback</span>(
    TIM_HandleTypeDef *htim) {
  <span class="kw">if</span> (htim->Instance == TIM2)
    edge_count++;
}

<span class="cm">/* Gate timer overflow (1 second) */</span>
<span class="kw">void</span> <span class="fn">HAL_TIM_PeriodElapsedCallback</span>(
    TIM_HandleTypeDef *htim) {
  <span class="kw">if</span> (htim->Instance == TIM3) {
    freq_result = edge_count;
    edge_count  = <span class="num">0</span>;
    meas_done   = <span class="num">1</span>;
  }
}

<span class="cm">/* Main measurement loop */</span>
<span class="kw">void</span> <span class="fn">freq_measure_task</span>(<span class="kw">void</span>) {
  <span class="kw">if</span> (meas_done) {
    meas_done = <span class="num">0</span>;
    <span class="kw">char</span> buf[<span class="num">32</span>];
    <span class="fn">sprintf</span>(buf, <span class="str">"FREQ:%lu Hz\r\n"</span>,
            freq_result);
    <span class="fn">HAL_UART_Transmit</span>(&huart2,
      (uint8_t*)buf, <span class="fn">strlen</span>(buf), <span class="num">100</span>);
    <span class="fn">update_display</span>(freq_result);
  }
}</div>
