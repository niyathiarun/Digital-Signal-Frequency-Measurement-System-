<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
let running=true,freq=1000,duty=50,noise=10,waveType='square';
let sampleCount=0,oscPhase=0,logTimer=0,veriChart=null;
let startTime=Date.now();

function sliderToFreq(v){const a=Math.log10(1),b=Math.log10(100000);return Math.pow(10,a+(v/100)*(b-a));}
function freqToSlider(f){const a=Math.log10(1),b=Math.log10(100000);return((Math.log10(f)-a)/(b-a))*100;}
function formatFreq(f){if(f>=1000)return(f/1000).toFixed(f>=10000?1:2)+' kHz';return f.toFixed(f<10?2:1)+' Hz';}

const oscC=document.getElementById('osc-canvas');
const gateC=document.getElementById('gate-canvas');
const oscCtx=oscC.getContext('2d');
const gateCtx=gateC.getContext('2d');

function resizeC(){
  [oscC,gateC].forEach(c=>{c.width=c.offsetWidth*devicePixelRatio||600;c.height=c.offsetHeight*devicePixelRatio||90;});
  const tc=document.getElementById('timing-canvas');
  if(tc){tc.width=tc.offsetWidth*devicePixelRatio||600;tc.height=200*devicePixelRatio;}
}

function drawOsc(){
  const W=oscC.width,H=oscC.height,ctx=oscCtx;
  ctx.clearRect(0,0,W,H);
  ctx.strokeStyle='rgba(0,255,136,0.06)';ctx.lineWidth=0.5;
  for(let x=0;x<W;x+=W/8){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=0;y<H;y+=H/4){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  const np=W/4,nA=(noise/100)*0.15*H,df=duty/100;
  ctx.beginPath();ctx.strokeStyle='#00ccff';ctx.lineWidth=1.5*devicePixelRatio;
  ctx.shadowColor='#00ccff';ctx.shadowBlur=4;
  for(let px=0;px<W;px++){
    const ph=((px/np)+oscPhase)%1;let v;const nz=(Math.random()-0.5)*nA;
    if(waveType==='square'||waveType==='glitch'){v=ph<df?0.15:0.85;if(waveType==='glitch'&&Math.random()<0.005)v=0.5+(Math.random()-0.5)*0.3;}
    else if(waveType==='sine'){v=0.5-0.4*Math.sin(2*Math.PI*ph);v=v<0.3?0.15:v>0.7?0.85:v;}
    else{const b=Math.floor(ph*5);v=(b%2===0)&&(ph*5-b)<df*0.5?0.15:0.85;}
    const y=v*H+nz;
    if(px===0)ctx.moveTo(px,y);else ctx.lineTo(px,y);
  }
  ctx.stroke();ctx.shadowBlur=0;
  ctx.strokeStyle='rgba(255,204,0,0.5)';ctx.lineWidth=0.5;ctx.setLineDash([4,3]);
  ctx.beginPath();ctx.moveTo(0,H*0.5);ctx.lineTo(W,H*0.5);ctx.stroke();ctx.setLineDash([]);
}

function drawGate(){
  const W=gateC.width,H=gateC.height,ctx=gateCtx;
  ctx.clearRect(0,0,W,H);
  const gp=(Date.now()/1000)%2,go=gp<1;
  ctx.strokeStyle='#ff6b35';ctx.lineWidth=1.5*devicePixelRatio;
  ctx.shadowColor='#ff6b35';ctx.shadowBlur=3;
  ctx.beginPath();
  const ex=(1-gp%1)*W;
  ctx.moveTo(0,H*0.8);
  if(go){ctx.lineTo(W-ex-W*0.5,H*0.8);ctx.lineTo(W-ex-W*0.5,H*0.2);ctx.lineTo(W,H*0.2);}
  else{ctx.lineTo(W-ex,H*0.8);if(W-ex<W){ctx.lineTo(W-ex,H*0.2);ctx.lineTo(W,H*0.2);}}
  ctx.stroke();ctx.shadowBlur=0;
}

const laChannels=[
  {name:'CH0',label:'SIG IN',color:'#00ff88',fm:1},
  {name:'CH1',label:'SCHMITT',color:'#00ccff',fm:1},
  {name:'CH2',label:'GATE',color:'#ff6b35',fm:0.002},
  {name:'CH3',label:'CLK÷1',color:'#ffcc00',fm:10},
  {name:'CH4',label:'EDGE DET',color:'#88ffcc',fm:1},
  {name:'CH5',label:'COUNT_EN',color:'#cc88ff',fm:0.001},
  {name:'CH6',label:'DATA_RDY',color:'#ff88cc',fm:0.0009},
  {name:'CH7',label:'UART TX',color:'#ffaa44',fm:0.05}
];

function buildLA(){
  const cont=document.getElementById('la-channels');
  cont.innerHTML='';
  laChannels.forEach((ch,i)=>{
    const r=document.createElement('div');r.className='la-row';
    r.innerHTML=`<div class="la-ch" style="color:${ch.color}">${ch.name}</div><div style="font-size:10px;min-width:52px;color:rgba(0,255,136,.4)">${ch.label}</div><div class="la-cwrap"><canvas class="la-sig" id="la-c-${i}" height="28"></canvas></div><div class="la-val" style="color:${ch.color};font-size:10px" id="la-v-${i}">—</div>`;
    cont.appendChild(r);
  });
}

function drawLA(idx){
  const c=document.getElementById(`la-c-${idx}`);if(!c)return;
  c.width=c.offsetWidth*devicePixelRatio||400;c.height=28*devicePixelRatio;
  const ctx=c.getContext('2d'),W=c.width,H=c.height,ch=laChannels[idx];
  ctx.clearRect(0,0,W,H);
  const cf=freq*ch.fm,period=W/(cf*0.0004+4),t=Date.now()*0.001;
  ctx.strokeStyle=ch.color;ctx.lineWidth=1.2*devicePixelRatio;ctx.beginPath();
  let high=false;
  for(let px=0;px<W;px++){
    const ph=((px/period)+t*cf*ch.fm*0.5)%1,wh=high;
    high=ph<0.5;const y=high?H*0.15:H*0.85,py=wh?H*0.15:H*0.85;
    if(px===0)ctx.moveTo(px,y);
    else if(wh!==high){ctx.lineTo(px,py);ctx.lineTo(px,y);}
    else ctx.lineTo(px,y);
  }
  ctx.stroke();
  const cp=(t*cf*ch.fm*0.5)%1;
  document.getElementById(`la-v-${idx}`).textContent=cp<0.5?'HIGH':'LOW';
}

function drawTiming(){
  const c=document.getElementById('timing-canvas');if(!c)return;
  c.width=c.offsetWidth*devicePixelRatio||600;c.height=200*devicePixelRatio;
  const ctx=c.getContext('2d'),W=c.width,H=c.height,dpr=devicePixelRatio;
  ctx.clearRect(0,0,W,H);ctx.font=`${10*dpr}px 'Share Tech Mono'`;
  const sigs=[
    {label:'REF CLK',color:'#ff6b35',type:'fast'},
    {label:'GATE EN',color:'#00ccff',type:'slow'},
    {label:'SIG IN',color:'#00ff88',type:'mid'},
    {label:'EDGE CNT',color:'#ffcc00',type:'count'},
    {label:'DATA_RDY',color:'#ff88cc',type:'pulse'}
  ];
  const rowH=H/(sigs.length+0.5),lW=70*dpr;
  sigs.forEach((sig,i)=>{
    const y0=(i+0.5)*rowH,sH=rowH*0.5,t=(Date.now()*0.001)%4,dW=W-lW-10*dpr,sX=lW;
    ctx.fillStyle=sig.color;ctx.globalAlpha=0.7;ctx.fillText(sig.label,4,y0+4);ctx.globalAlpha=1;
    ctx.strokeStyle=sig.color;ctx.lineWidth=1.2*dpr;ctx.beginPath();
    if(sig.type==='fast'){
      const p=dW/16;
      for(let px=0;px<dW;px++){
        const ph=(px/p+t*4)%1,y=ph<0.5?y0-sH/2:y0+sH/2;
        if(px===0)ctx.moveTo(sX+px,y);
        else{const pp=((px-1)/p+t*4)%1;if((pp<0.5)!==(ph<0.5)){ctx.lineTo(sX+px,y0-sH/2+(ph<0.5?0:sH));ctx.lineTo(sX+px,y);}else ctx.lineTo(sX+px,y);}
      }
    } else if(sig.type==='slow'){
      const of=(t%2)/2,gx=sX+of*dW;
      ctx.moveTo(sX,y0+sH/2);ctx.lineTo(gx,y0+sH/2);ctx.lineTo(gx,y0-sH/2);ctx.lineTo(sX+dW,y0-sH/2);
    } else if(sig.type==='mid'){
      const fM=Math.max(3,Math.min(12,freq/200)),p=dW/fM;
      for(let px=0;px<dW;px++){
        const ph=(px/p+t*1.5)%1,y=ph<duty/100?y0-sH/2:y0+sH/2;
        if(px===0)ctx.moveTo(sX+px,y);
        else{const pp=((px-1)/p+t*1.5)%1;if((pp<duty/100)!==(ph<duty/100)){const py=pp<duty/100?y0-sH/2:y0+sH/2;ctx.lineTo(sX+px,py);ctx.lineTo(sX+px,y);}else ctx.lineTo(sX+px,y);}
      }
    } else if(sig.type==='count'){
      const steps=8,sw=dW/steps;
      ctx.moveTo(sX,y0+sH/2);
      for(let s=0;s<steps;s++){const h=(s/(steps-1))*sH;ctx.lineTo(sX+s*sw,y0+sH/2-h);ctx.lineTo(sX+(s+1)*sw,y0+sH/2-h);}
    } else {
      ctx.moveTo(sX,y0+sH/2);ctx.lineTo(sX+dW*0.9,y0+sH/2);ctx.lineTo(sX+dW*0.9,y0-sH/2);ctx.lineTo(sX+dW*0.95,y0-sH/2);ctx.lineTo(sX+dW*0.95,y0+sH/2);ctx.lineTo(sX+dW,y0+sH/2);
    }
    ctx.stroke();
    ctx.strokeStyle='rgba(0,255,136,.06)';ctx.lineWidth=0.5;ctx.beginPath();ctx.moveTo(0,y0+rowH/2);ctx.lineTo(W,y0+rowH/2);ctx.stroke();
  });
  const gx=lW+((Date.now()*0.001%2)/2)*(W-lW-10*dpr);
  ctx.strokeStyle='rgba(255,204,0,.4)';ctx.setLineDash([4,3]);ctx.lineWidth=0.8*dpr;
  ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();ctx.setLineDash([]);
  ctx.fillStyle='rgba(255,204,0,.6)';ctx.fillText('T_GATE',gx+4,14*dpr);
}

function buildVerification(){
  const tcs=[
    {name:'1 Hz Square',expected:1,method:'Gate Count'},
    {name:'100 Hz Square',expected:100,method:'Gate Count'},
    {name:'1 kHz PWM',expected:1000,method:'Gate Count'},
    {name:'10 kHz Burst',expected:10000,method:'Reciprocal'},
    {name:'50 kHz Sine→Sq',expected:50000,method:'Reciprocal'},
    {name:'Glitch Filter',expected:1000,method:'Debounce'},
    {name:'Duty Cycle 25%',expected:1000,method:'Period Meas'},
    {name:'Duty Cycle 75%',expected:1000,method:'Period Meas'},
  ];
  const tbody=document.getElementById('veri-table-body');tbody.innerHTML='';
  let pass=0,warn=0,fail=0;const errors=[];
  tcs.forEach(tc=>{
    const err=(Math.random()*0.8-0.1),meas=tc.expected*(1+err*0.001+(Math.random()-0.5)*0.0002);
    const pct=Math.abs((meas-tc.expected)/tc.expected*100);
    const st=pct<0.01?'PASS':pct<0.1?'WARN':'FAIL';
    if(st==='PASS')pass++;else if(st==='WARN')warn++;else fail++;
    errors.push(pct);
    const tr=document.createElement('tr'),cls=st==='PASS'?'pass':st==='WARN'?'warn':'fail';
    tr.innerHTML=`<td>${tc.name}</td><td>${tc.expected>=1000?(tc.expected/1000).toFixed(tc.expected>=10000?0:1)+' kHz':tc.expected+' Hz'}</td><td style="color:var(--crt)">${meas>=1000?(meas/1000).toFixed(meas>=10000?1:2)+' kHz':meas.toFixed(2)+' Hz'}</td><td class="${cls}">${pct<0.001?'<0.001':pct.toFixed(3)}%</td><td class="${cls}">${st}</td><td style="color:rgba(0,255,136,.5)">${tc.method}</td>`;
    tbody.appendChild(tr);
  });
  document.getElementById('veri-summary').innerHTML=`<div>Tests Run: <span style="color:var(--crt)">${tcs.length}</span></div><div>Passed: <span class="pass">${pass}</span></div><div>Warnings: <span class="warn">${warn}</span></div><div>Failed: <span class="fail">${fail}</span></div><div style="margin-top:6px">Max Error: <span style="color:var(--crt)">${Math.max(...errors).toFixed(4)}%</span></div><div>Avg Error: <span style="color:var(--crt)">${(errors.reduce((a,b)=>a+b,0)/errors.length).toFixed(4)}%</span></div><div style="margin-top:6px;color:rgba(0,255,136,.5)">Resolution: 0.1 Hz @ 1s gate</div><div style="color:rgba(0,255,136,.5)">Ref: 10 MHz TCXO ±1ppm</div>`;
  const ec=document.getElementById('error-canvas');if(!ec)return;
  if(veriChart){veriChart.destroy();veriChart=null;}
  veriChart=new Chart(ec,{type:'bar',data:{labels:tcs.map(t=>t.name.split(' ')[0]),datasets:[{label:'Error %',data:errors.map(e=>+e.toFixed(4)),backgroundColor:errors.map(e=>e<0.01?'rgba(0,255,136,0.5)':e<0.1?'rgba(255,204,0,0.6)':'rgba(255,107,53,0.7)'),borderColor:errors.map(e=>e<0.01?'#00ff88':e<0.1?'#ffcc00':'#ff6b35'),borderWidth:1}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'rgba(0,255,136,0.5)',font:{size:9,family:"'Share Tech Mono'"}},grid:{color:'rgba(0,255,136,0.06)'}},y:{ticks:{color:'rgba(0,255,136,0.5)',font:{size:9}},grid:{color:'rgba(0,255,136,0.06)'}}}}});
}

function logEvent(msg,type='ok'){
  const log=document.getElementById('evt-log');
  const t=((Date.now()-startTime)/1000).toFixed(3);
  const d=document.createElement('div');d.className=`evt-${type}`;
  d.innerHTML=`<span class="evt-ts">[${t}s]</span>${msg}`;
  log.appendChild(d);log.scrollTop=log.scrollHeight;
  if(log.children.length>80)log.removeChild(log.children[0]);
}

function updateFreq(v){freq=sliderToFreq(v);document.getElementById('freq-ctrl-val').textContent=formatFreq(freq);logEvent(`Frequency set → ${formatFreq(freq)}`,'info');}
function updateDuty(v){duty=parseInt(v);document.getElementById('duty-ctrl-val').textContent=duty+'%';}
function updateNoise(v){noise=parseInt(v);document.getElementById('noise-ctrl-val').textContent=v+'%';}
function updateWave(v){waveType=v;logEvent(`Waveform → ${v.toUpperCase()}`,'info');}
function toggleRun(){running=!running;const b=document.getElementById('btn-run');b.textContent=running?'■ RUNNING':'▶ PAUSED';b.classList.toggle('active',running);logEvent(running?'Measurement RESUMED':'Measurement PAUSED',running?'ok':'warn');}
function triggerSingle(){logEvent('SINGLE trigger captured — snapshot taken','info');}
function autoRange(){document.getElementById('freq-ctrl').value=Math.round(freqToSlider(freq));logEvent('Auto-range complete — timebase adjusted','ok');}
function resetStats(){sampleCount=0;logEvent('Statistics reset','warn');}

function switchTab(name){
  document.querySelectorAll('.tab').forEach((t,i)=>{const tabs=['simulation','design','implementation','logic','verification'];t.classList.toggle('active',tabs[i]===name);});
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='logic'){buildLA();resizeC();}
  if(name==='verification')buildVerification();
}

function animate(){
  if(running){
    sampleCount++;
    oscPhase=(oscPhase+freq*0.00002)%1;
    const period=1/freq;
    const ps=period<0.001?(period*1e6).toFixed(2)+'μs':period<1?(period*1000).toFixed(3)+'ms':period.toFixed(3)+'s';
    const omega=(2*Math.PI*freq).toFixed(1);
    const jitter=freq>10000?'±8ns':freq>1000?'±4ns':'±2ns';
    const rt=freq>10000?'50ns':freq>1000?'100ns':'500ns';
    const snr=Math.max(30,70-noise*0.4).toFixed(0);
    document.getElementById('freq-readout').innerHTML=formatFreq(freq);
    document.getElementById('period-readout').textContent=`Period: ${ps}  |  ω = ${omega} rad/s`;
    document.getElementById('met-duty').textContent=duty.toFixed(1)+'%';
    document.getElementById('met-rise').textContent=rt;
    document.getElementById('met-jitter').textContent=jitter;
    document.getElementById('met-snr').textContent=snr+'dB';
    document.getElementById('met-edges').textContent=Math.round(freq*2).toLocaleString();
    const el=Date.now()-startTime;
    const h=String(Math.floor(el/3600000)).padStart(2,'0'),m=String(Math.floor(el/60000)%60).padStart(2,'0'),s=String(Math.floor(el/1000)%60).padStart(2,'0'),ms=String(el%1000).padStart(3,'0');
    document.getElementById('clock-display').textContent=`${h}:${m}:${s}.${ms}`;
    document.getElementById('sample-count').textContent=`SAMPLES: ${sampleCount.toLocaleString()}`;
    drawOsc();drawGate();
    const lt=document.getElementById('tab-logic');
    if(lt&&lt.classList.contains('active')){laChannels.forEach((_,i)=>drawLA(i));drawTiming();if(document.getElementById('la-dt'))document.getElementById('la-dt').textContent=`${(1000000/freq).toFixed(1)}μs`;}
    logTimer++;
    if(logTimer%60===0){
      const ms2=[['Gate open — counting edges at '+formatFreq(freq),'ok'],['Edge count: '+Math.round(freq)+' pulses in 1.000s gate','ok'],['Result latched: '+formatFreq(freq)+' — SNR='+snr+'dB','ok'],['UART TX: FREQ:'+Math.round(freq)+' Hz — checksum OK','info'],noise>50?['High noise ('+noise+'%) — SNR degraded','warn']:['Signal quality: GOOD — noise='+noise+'%','ok']];
      const p=ms2[Math.floor(logTimer/60)%ms2.length];logEvent(p[0],p[1]);
    }
  }
  requestAnimationFrame(animate);
}

window.addEventListener('load',()=>{
  resizeC();buildLA();
  logEvent('System initialized — DSFMS-v2.4','ok');
  logEvent('Reference clock 10 MHz TCXO locked ✓','ok');
  logEvent('Schmitt trigger threshold: VCC/2','info');
  logEvent('32-bit gate counter armed','ok');
  logEvent('Gate time: 1.000s — resolution: 0.1 Hz','info');
  logEvent('UART 115200 baud TX enabled','ok');
  logEvent('Simulation running — adjust controls to test','ok');
  animate();
});
window.addEventListener('resize',resizeC);
</script>
