/uart_output
#include "freq_measure.h"
#include <stdio.h>
#include <string.h>

extern UART_HandleTypeDef huart2;

void uart_send_freq(uint32_t freq_hz) {
  char buf[64];
  if (freq_hz >= 1000)
    sprintf(buf, "FREQ: %.3f kHz\r\n", freq_hz / 1000.0f);
  else
    sprintf(buf, "FREQ: %lu Hz\r\n", freq_hz);
  HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), 100);
}
