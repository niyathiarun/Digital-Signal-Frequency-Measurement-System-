/* Main measurement loop */
void freq_measure_task(void) 
{ 
if (meas_done) {
meas_done = 0; 
char buf[32]; 
sprintf(buf, "FREQ:%lu Hz\r\n", freq_result); 
HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), 100); 
